{
	"name": "n8n-nodes-mihu",
	"version": "0.1.1",
	"description": "n8n community node for Mihu AI - AI-powered contact center and voice agent platform",
	"license": "MIT",
	"homepage": "https://mihu.ai",
	"keywords": [
		"n8n-community-node-package",
		"mihu",
		"ai",
		"voice-agent",
		"contact-center",
		"automation"
	],
	"author": {
		"name": "Mihu AI",
		"email": "info@mihu.ai"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mihu-ai/n8n-nodes-mihu.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MihuApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Mihu/Mihu.node.js",
			"dist/nodes/Mihu/MihuTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}